#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# Git pre-push hook：混淆规则同步检查
#
# 安装方式（运行一次）：
#   bash scripts/install-hooks.sh
#
# 跳过检查：
#   git push --no-verify
# ──────────────────────────────────────────────────────────────────────────────

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/scripts/check_obfuscation_rules.py"

# 未找到脚本时静默跳过，不阻断推送
if [ ! -f "$SCRIPT" ]; then
  exit 0
fi

# 读取 pre-push 提供的 stdin（remote ref 信息）
# 格式：<local_ref> <local_sha> <remote_ref> <remote_sha>
# 找出 base branch（取 remote 分支，或 fallback 到 master）
BASE_BRANCH="master"
while read local_ref local_sha remote_ref remote_sha; do
  # 如果 remote 已有对应分支，用它做 diff base
  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
    BASE_BRANCH="$remote_sha"
    break
  fi
done

python3 "$SCRIPT" --base "$BASE_BRANCH" --strict
EXIT_CODE=$?

exit $EXIT_CODE
