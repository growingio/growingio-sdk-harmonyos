{
  "agent": "GrowingIO HarmonyOS SDK Engineer",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "python3 scripts/check_obfuscation_rules.py --hook-mode",
            "timeout": 30,
            "statusMessage": "检查混淆规则同步状态..."
          }
        ]
      }
    ]
  }
}
